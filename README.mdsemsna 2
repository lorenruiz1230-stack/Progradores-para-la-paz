# Progradores-para-la-paz
body {
    font-family: Arial, sans-serif;
    margin: 20px;
    line-height: 1.5;
    background-color: #f5f5f5;
  }
  
  main {
    max-width: 700px;
    margin: 0 auto;
  }
  
  .contenedor {
    background-color: red;
    padding: 25px;
    border-radius: 7px;
  }
  
  h1 {
    font-size: 29px;
    margin-bottom: 15px;
  }
  
  p {
    font-size: 15px;
  }
  
  form {
    margin-top: 23px;
  }
  
  .campo {
    margin-bottom: 18px;
  }
  
  label {
    display: block;
    margin-bottom: 8px;
  }
  
  input,
  textarea {
    width: 100%;
    padding: 8px;
    font-size: 16px;
    box-sizing: border-box;
  }
  
  textarea {
    min-height: 120px;
  }
  
  button {
    padding: 10px 16px;
    font-size: 16px;
    cursor: pointer;
  }
  
